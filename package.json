{
  "name": "neogeek.dev",
  "type": "module",
  "devDependencies": {
    "@types/node": "25.5.0",
    "highlight.js": "11.11.1",
    "marked": "18.0.5",
    "marked-footnote": "1.4.0",
    "marked-highlight": "2.2.4",
    "onlybuild": "2.2.0",
    "yaml": "2.9.0"
  },
  "scripts": {
    "build": "onlybuild",
    "watch": "NODE_ENV=development npx nodemon --ext \"*.*\" --ignore ./build -x \"npm run build\"",
    "serve": "npx http-server ./build -o",
    "dev": "npx concurrently \"npm run watch\" \"npm run serve\""
  },
  "private": true
}
